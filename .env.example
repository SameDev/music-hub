# Optional. docker-compose.yml / docker-compose.release.yml both run with zero
# .env file using the defaults baked into each variable below — copy this file
# and edit it only if you want to override something (real secrets, a custom
# CORS origin, etc.).

POSTGRES_USER=musichub
POSTGRES_PASSWORD=changeme
POSTGRES_DB=musichub
DATABASE_URL=postgresql://musichub:changeme@postgres:5432/musichub

REDIS_HOST=redis
REDIS_PORT=6379

PORT=3000
NODE_ENV=development
JWT_SECRET=changeme_generate_a_long_random_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=changeme_generate_a_different_long_random_secret
JWT_REFRESH_EXPIRES_IN=7d
CORS_ORIGIN=
LIBRARY_PATH=/data/library
DOWNLOAD_TMP_PATH=/data/tmp

# Host path bind-mounted into the container at /data/library (your music files)
MUSICHUB_LIBRARY_PATH=/DATA/Media/Music

ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme_use_a_strong_password

VITE_API_URL=

# Host port nginx binds to
MUSICHUB_PORT=8095
